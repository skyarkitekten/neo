{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.agent-hooks/log-event.sh\" SessionStart" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.agent-hooks/log-event.sh\" UserPromptSubmit" } ] }
    ],
    "PostToolUse": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.agent-hooks/log-event.sh\" PostToolUse" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.agent-hooks/log-event.sh\" Stop" } ] }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.agent-hooks/log-event.sh\" SubagentStop" } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.agent-hooks/log-event.sh\" PreCompact" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.agent-hooks/log-event.sh\" SessionEnd" } ] }
    ]
  }
}
